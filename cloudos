#!/usr/bin/env bash
# CloudOS — Personal cloud, modular & distributed
set -euo pipefail

CLOUDOS_ROOT="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
CLOUDOS_VERSION="0.1.0"

# Load libs
source "${CLOUDOS_ROOT}/lib/colors.sh"
source "${CLOUDOS_ROOT}/lib/utils.sh"

# ─── Commands ────────────────────────────────────────────────────────

cmd_init() {
  source "${CLOUDOS_ROOT}/lib/detect.sh"
  detect_all

  # Generate config
  cat > cloudos.yml << EOF
# CloudOS configuration — auto-generated by cloudos init
version: ${CLOUDOS_VERSION}
created: $(date -u +%Y-%m-%dT%H:%M:%SZ)
system:
  os: ${CLOUDOS_OS}
  arch: ${CLOUDOS_ARCH}
  ram_gb: ${CLOUDOS_RAM_GB}
  gpu: ${CLOUDOS_GPU}
  disk: "${CLOUDOS_DISK}"
network:
  nat: ${CLOUDOS_NAT}
  gateway: ${CLOUDOS_GATEWAY}
  tailscale: ${CLOUDOS_TAILSCALE}
  tailscale_ip: ${CLOUDOS_TAILSCALE_IP:-}
modules: {}
services:
  detected: ${CLOUDOS_SERVICES}
EOF

  log_ok "Configuration saved to cloudos.yml"
  
  # Recommend modules
  echo -e "\n${BOLD}Recommended modules based on your hardware:${NC}"
  if [ "$CLOUDOS_RAM_GB" -ge 8 ]; then
    echo "  ✓ filesync  (Nextcloud) — minimum 2GB RAM"
    echo "  ✓ photos    (Immich)    — minimum 4GB RAM"
  fi
  if [ "$CLOUDOS_RAM_GB" -ge 16 ]; then
    echo "  ✓ ai        (Ollama+WebUI) — minimum 8GB RAM"
  fi
  if [ "$CLOUDOS_DOCKER" = "yes" ]; then
    echo "  ✓ auth      (Authentik+Caddy) — lightweight"
    echo "  ✓ search    (SearXNG) — lightweight"
  fi
  
  echo -e "\nRun: ${CYAN}cloudos module add <name>${NC} to add modules"
}

cmd_up() {
  if [ ! -f cloudos.yml ]; then
    log_warn "No cloudos.yml found. Running cloudos init first..."
    cmd_init
  fi
  
  log_step "Starting CloudOS..."
  
  if [ "$CLOUDOS_DOCKER" != "yes" ]; then
    log_error "Docker is not running."
    echo "  Install Docker first: cloudos setup docker"
    exit 1
  fi
  
  # Find and start all compose files in modules
  local compose_files=""
  for module_dir in "${CLOUDOS_ROOT}"/modules/*/; do
    local name
    name=$(basename "$module_dir")
    local yml="${module_dir}/docker-compose.yml"
    if [ -f "$yml" ]; then
      compose_files="${compose_files} -f ${yml}"
      log_ok "Module ${name}: docker-compose.yml found"
    fi
  done
  
  if [ -z "$compose_files" ]; then
    log_warn "No modules installed. Run: cloudos module add <name>"
    exit 0
  fi
  
  log_step "Deploying stack..."
  # shellcheck disable=SC2086
  docker compose $compose_files -p cloudos up -d 2>&1 || {
    log_error "Deploy failed"
    exit 1
  }
  
  log_ok "CloudOS is running!"
  cmd_status
}

cmd_status() {
  log_header "CloudOS Status"
  
  # System info
  echo -e "\n${BOLD}System:${NC}"
  if [ -f cloudos.yml ]; then
    echo "  Config:   cloudos.yml $(grep 'created:' cloudos.yml | head -1)"
  fi
  echo "  Version:  ${CLOUDOS_VERSION}"
  
  # Docker status
  if docker_running; then
    echo "  Docker:   running"
    
    # Running containers
    local containers
    containers=$(docker ps --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}' 2>/dev/null | tail -n +2 || true)
    if [ -n "$containers" ]; then
      echo -e "\n${BOLD}Containers:${NC}"
      echo "$containers" | while IFS= read -r line; do
        local name status
        name=$(echo "$line" | awk '{print $1}')
        status=$(echo "$line" | awk '{print $3}')
        if echo "$status" | grep -q "Up"; then
          echo -e "  ${GREEN}●${NC} $line"
        else
          echo -e "  ${RED}○${NC} $line"
        fi
      done
    fi
  else
    echo "  Docker:   not running"
  fi
  
  # Tailscale
  if has_cmd tailscale; then
    local ts_status
    ts_status=$(tailscale status 2>/dev/null | head -3 || true)
    if [ -n "$ts_status" ]; then
      echo -e "\n${BOLD}Tailscale:${NC}"
      echo "$ts_status" | while IFS= read -r line; do
        echo "  ${GRAY}●${NC} $line"
      done
    fi
  fi
  
  echo ""
}

cmd_module() {
  local action="${1:-}"
  local module="${2:-}"
  
  case "$action" in
    add)
      if [ -z "$module" ]; then
        log_error "Usage: cloudos module add <name>"
        echo "  Available: auth filesync search photos ai media mail"
        exit 1
      fi
      
      local module_path="${CLOUDOS_ROOT}/modules/${module}"
      local module_lib="${CLOUDOS_ROOT}/${module}/setup.sh"
      
      if [ -f "${module_lib}" ]; then
        log_step "Adding module: ${module}"
        source "${module_lib}"
        "${module}_setup"
        log_ok "Module ${module} added"
      else
        log_error "Module '${module}' not found"
        echo "  Run: ls cloudos/modules/ to see available modules"
        exit 1
      fi
      ;;
    list)
      echo -e "${BOLD}Available modules:${NC}"
      for mod_dir in "${CLOUDOS_ROOT}"/modules/*/; do
        local name
        name=$(basename "$mod_dir")
        local desc=""
        [ -f "${mod_dir}/module.yml" ] && desc=$(grep 'description:' "${mod_dir}/module.yml" | sed 's/description: *//')
        local status="${GRAY}not installed${NC}"
        [ -f "${mod_dir}/docker-compose.yml" ] && status="${GREEN}installed${NC}"
        echo -e "  ${name}\t${desc}\t(${status})"
      done
      ;;
    *)
      echo "Usage: cloudos module {add|list} [name]"
      ;;
  esac
}

cmd_setup() {
  local component="${1:-}"
  case "$component" in
    docker)
      log_step "Installing Docker..."
      case "$(get_os)" in
        linux)
          curl -fsSL https://get.docker.com | bash
          ;;
        windows)
          log_info "Windows: use Docker Desktop or: winget install Docker.DockerDesktop"
          ;;
        macos)
          log_info "macOS: use Docker Desktop or: brew install --cask docker"
          ;;
      esac
      ;;
    tailscale)
      log_step "Installing Tailscale..."
      curl -fsSL https://tailscale.com/install.sh | bash
      log_info "After install: tailscale up --ssh"
      ;;
    *)
      echo "Usage: cloudos setup {docker|tailscale}"
      ;;
  esac
}

cmd_profile() {
  local action="${1:-}"
  local profile="${2:-}"
  local profiles_yml="${CLOUDOS_ROOT}/profiles/profiles.yml"

  case "$action" in
    list)
      echo -e "${BOLD}Available profiles:${NC}"
      echo ""
      
      local name="" desc="" ram="" disk="" modules_str=""
      while IFS= read -r line; do
        local trimmed
        trimmed=$(echo "$line" | sed 's/^[[:space:]]*//')
        if [[ "$trimmed" =~ ^-\ name:[[:space:]]*(.*) || "$trimmed" =~ ^name:[[:space:]]*(.*) ]]; then
          if [ -n "$name" ]; then
            echo -e "  ${CYAN}${name}${NC} (${ram}GB RAM / ${disk}GB disk)"
            echo -e "    ${desc}"
            echo -e "    Modules: ${modules_str}"
            echo ""
          fi
          name="${BASH_REMATCH[1]}"
          desc=""; ram=""; disk=""; modules_str=""
        elif [[ "$trimmed" =~ ^desc:[[:space:]]*\"(.*)\" ]]; then
          desc="${BASH_REMATCH[1]}"
        elif [[ "$trimmed" =~ ^ram:[[:space:]]*([0-9]+) ]]; then
          ram="${BASH_REMATCH[1]}"
        elif [[ "$trimmed" =~ ^disk:[[:space:]]*([0-9]+) ]]; then
          disk="${BASH_REMATCH[1]}"
        elif [[ "$trimmed" =~ ^modules:[[:space:]]*\[(.*)\] ]]; then
          modules_str="${BASH_REMATCH[1]}"
        fi
      done < "$profiles_yml"
      # Last profile
      if [ -n "$name" ]; then
        echo -e "  ${CYAN}${name}${NC} (${ram}GB RAM / ${disk}GB disk)"
        echo -e "    ${desc}"
        echo -e "    Modules: ${modules_str}"
        echo ""
      fi
      ;;
    apply)
      if [ -z "$profile" ]; then
        log_error "Usage: cloudos profile apply <name>"
        return 1
      fi
      
      # Find profile modules
      local in_target=0 modules_list=""
      while IFS= read -r line; do
        local trimmed
        trimmed=$(echo "$line" | sed 's/^[[:space:]]*//')
        if [[ "$trimmed" =~ ^-\ name:[[:space:]]*(.*) || "$trimmed" =~ ^name:[[:space:]]*(.*) ]]; then
          [ "${BASH_REMATCH[1]}" = "$profile" ] && in_target=1 || in_target=0
        fi
        if [ "$in_target" = 1 ] && [[ "$trimmed" =~ ^modules:[[:space:]]*\[(.*)\] ]]; then
          modules_list="${BASH_REMATCH[1]}"
          # Also check extras
        fi
        if [ "$in_target" = 1 ] && [[ "$trimmed" =~ ^extras:[[:space:]]*\[(.*)\] ]]; then
          modules_list="${modules_list}, ${BASH_REMATCH[1]}"
        fi
      done < "$profiles_yml"
      
      if [ -z "$modules_list" ]; then
        log_error "Profile '${profile}' not found"
        return 1
      fi
      
      log_step "Applying profile: ${profile}"
      docker network inspect cloudos >/dev/null 2>&1 || docker network create cloudos
      
      IFS=',' read -ra modules <<< "$modules_list"
      for mod in "${modules[@]}"; do
        mod=$(echo "$mod" | xargs)  # trim
        local yml="${CLOUDOS_ROOT}/modules/${mod}/docker-compose.yml"
        local setup="${CLOUDOS_ROOT}/modules/${mod}/setup.sh"
        local legacy="${CLOUDOS_ROOT}/${mod}/setup.sh"
        
        if [ -f "$legacy" ]; then
          log_step "Setting up module: ${mod}"
          source "$legacy"
          "${mod}_setup" || log_warn "Setup for ${mod} had issues"
        elif [ -f "$setup" ]; then
          log_step "Setting up module: ${mod}"
          source "$setup"
          "${mod}_setup" || log_warn "Setup for ${mod} had issues"
        elif [ -f "$yml" ]; then
          log_info "Starting module: ${mod}"
          (cd "${CLOUDOS_ROOT}/modules/${mod}" && docker compose up -d 2>&1 | tail -2)
        else
          log_warn "Module '${mod}' not found — skipping"
        fi
      done
      
      log_ok "Profile '${profile}' applied!"
      cmd_status
      ;;
    *)
      echo "Usage: cloudos profile {list|apply} [name]"
      ;;
  esac
}

cmd_version() {
  echo "CloudOS v${CLOUDOS_VERSION}"
}

# ─── Help ────────────────────────────────────────────────────────────

cmd_help() {
  echo -e "${BOLD}CloudOS v${CLOUDOS_VERSION}${NC} — Personal cloud, modular & distributed\n"
  echo -e "${BOLD}Usage:${NC}"
  echo "  cloudos init              Detect environment & generate config"
  echo "  cloudos up                Deploy all active modules"
  echo "  cloudos status            Show running services"
  echo "  cloudos profile list      List available profiles"
  echo "  cloudos profile apply <n> Install modules from a profile"
  echo "  cloudos module add <name> Install a module"
  echo "  cloudos module list       List available modules"
  echo "  cloudos setup docker      Install Docker"
  echo "  cloudos setup tailscale   Install Tailscale"
  echo "  cloudos version           Show version"
  echo ""
  echo -e "${BOLD}Modules:${NC}"
  echo "  auth       Authentik + Caddy (SSO, SSL reverse proxy)"
  echo "  filesync   Nextcloud + OnlyOffice (file sync & docs)"
  echo "  search     SearXNG + Meilisearch (private search)"
  echo "  photos     Immich (Google Photos alternative)"
  echo "  ai         Ollama + Open WebUI + Hermes supervisor"
  echo "  media      Jellyfin + Navidrome (movies, music)"
  echo "  mail       Mailcow (self-hosted email)"
}

# ─── CLI Router ──────────────────────────────────────────────────────

case "${1:-help}" in
  init)    cmd_init ;;
  up)      cmd_up ;;
  status)  cmd_status ;;
  profile) shift; cmd_profile "$@" ;;
  module)  shift; cmd_module "$@" ;;
  setup)   shift; cmd_setup "$@" ;;
  version) cmd_version ;;
  help|*)  cmd_help ;;
esac
